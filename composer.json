{
    "name": "knlab/pb-migrate",
    "description": "CLI tool to sync local AIML projects with Pandorabots",
    "keywords": ["pandorabots", "aiml", "cli", "chatbot", "migration"],
    "type": "project",
    "license": "MIT",
    "authors": [
        {
            "name": "knlab",
            "email": "35491752+knlab@users.noreply.github.com"
        }
    ],
    "bin": ["bin/pb-migrate"],
    "require": {
        "php": "^8.1",
        "ext-json": "*",
        "spontena/pb-php": "^2.1.2",
        "symfony/console": "^6.4 || ^7.0",
        "symfony/dotenv": "^6.4 || ^7.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.5",
        "phpstan/phpstan": "^1.11",
        "justinrainbow/json-schema": "^6.8"
    },
    "minimum-stability": "stable",
    "autoload": {
        "psr-4": {
            "KnLab\\PbMigrate\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "KnLab\\PbMigrate\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit",
        "test:integration": "phpunit --testsuite integration",
        "analyse": "phpstan analyse src --level=6"
    }
}
